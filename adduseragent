🚀 3. activate.txt

This is the bootstrap installer that the user runs once.

It:

1. Creates the folder structure
2. Moves Structure.txt + Listener.txt into C:\tools\cmrmd
3. Renames them to .ps1
4. Launches the listener


# activate.txt
# Bootstrap installer for CMR MiniDash local agent

$root = Split-Path -Parent $MyInvocation.MyCommand.Path
$base = "C:\tools"
$cmr = "C:\tools\cmrmd"

# Ensure directories exist
if (!(Test-Path $base)) { New-Item -ItemType Directory -Path $base -Force }
if (!(Test-Path $cmr)) { New-Item -ItemType Directory -Path $cmr -Force }

# Move and rename scripts
if (Test-Path "$root\Structure.txt") {
    Move-Item "$root\Structure.txt" "$cmr\Structure.ps1" -Force
}

if (Test-Path "$root\Listener.txt") {
    Move-Item "$root\Listener.txt" "$cmr\Listener.ps1" -Force
}

# Run Structure.ps1
if (Test-Path "$cmr\Structure.ps1") {
    Write-Host "Running Structure.ps1..."
    powershell -ExecutionPolicy Bypass -File "$cmr\Structure.ps1"
}

# Launch Listener.ps1
if (Test-Path "$cmr\Listener.ps1") {
    Write-Host "Launching Listener.ps1..."
    Start-Process powershell -ArgumentList "-ExecutionPolicy Bypass -File `"$cmr\Listener.ps1`""
}

Write-Host "CMR MiniDash local agent installed and running."


